# Supabase – PostgreSQL connection string
# Find under: Supabase Dashboard → Settings → Database → Connection string (URI)
SUPABASE_CONNECTION_STRING=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres

# Google AI Studio – Gemini 2.0 Flash
# Generate at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-google-ai-studio-api-key
