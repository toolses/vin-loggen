{
  "name": "vin-loggen-client",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "node scripts/set-env-dev.mjs && ng serve",
    "start:docker": "ng serve --host 0.0.0.0 --port 4200 --proxy-config proxy.conf.docker.json",
    "build": "ng build",
    "build:prod": "node scripts/set-env.mjs && ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/service-worker": "^21.0.0",
    "@supabase/supabase-js": "^2.50.0",
    "html-to-image": "^1.11.13",
    "mapbox-gl": "^3.21.0",
    "marked": "^18.0.0",
    "rxjs": "~7.8.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/mapbox-gl": "^3.4.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.9.0",
    "vitest": "^4.1.4",
    "zone.js": "~0.15.0"
  }
}
