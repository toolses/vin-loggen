{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Integration": {
    "EnableGemini": true,
    "EnableWineApi": true,
    "GeminiMaxDailyRequests": 500,
    "WineApiMaxDailyRequests": 100,
    "EnableVinmonopolet": false,
    "DailyProLimit": 10,
    "WineApi": {
      "BaseUrl": "https://api.wineapi.io",
      "AuthHeader": "X-API-Key",
      "AuthPrefix": ""
    },
    "DeepSeek": {
      "BaseUrl": "https://api.deepseek.com"
    },
    "AiFallback": {
      "LabelScanPriority": [ "Gemini" ],
      "ExpertChatPriority": [ "Groq", "DeepSeek", "Gemini" ],
      "EnrichmentPriority": [ "DeepSeek", "Groq", "Gemini" ],
      "GroqTokenBudgetPerMinute": 5500
    }
  }
}
