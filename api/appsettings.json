{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Integration": {
    "EnableGemini": true,
    "EnableWineApi": true,
    "EnableVinmonopolet": false,
    "DailyProLimit": 10,
    "WineApi": {
      "BaseUrl": "https://api.wineapi.io",
      "AuthHeader": "Authorization",
      "AuthPrefix": "Bearer "
    }
  }
}
